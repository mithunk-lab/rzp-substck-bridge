# PostgreSQL connection string — Railway provides this automatically when you attach a Postgres plugin
DATABASE_URL=

# Webhook secret from Razorpay dashboard (Settings → Webhooks) — used to verify every inbound webhook signature
RAZORPAY_WEBHOOK_SECRET=

# Full URL of your Substack publication, e.g. https://thewire.substack.com
SUBSTACK_PUBLICATION_URL=

# Value of the substack.sid session cookie — log in to Substack as the editor account, open DevTools → Application → Cookies, copy the value
SUBSTACK_SESSION_COOKIE=

# SMTP hostname for sending clarification emails to subscribers, e.g. smtp.gmail.com
SMTP_HOST=

# SMTP port — 587 for STARTTLS, 465 for SSL
SMTP_PORT=

# SMTP login username (usually your email address)
SMTP_USER=

# SMTP password or app-specific password
SMTP_PASSWORD=

# From address that appears on clarification emails, e.g. subscriptions@thewire.in
CLARIFICATION_EMAIL_FROM=

# Strong random string that protects all dashboard API endpoints — generate with: openssl rand -hex 32
DASHBOARD_API_KEY=

# URL where the frontend dashboard is hosted — used for CORS and links inside emails
FRONTEND_URL=

# Run Playwright browser in headless mode — set false locally to debug automation
PLAYWRIGHT_HEADLESS=true

# When true, identity resolution and comp calculations run but no changes are made in Substack
DRY_RUN=false

# deployment environment: development | production
ENVIRONMENT=production
